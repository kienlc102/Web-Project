PORT=3004

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email Settings
EMAIL_FROM=tttt@test.com
EMAIL_FROM_NAME=My mail

# RabbitMQ
RABBITMQ_URL=amqp://admin:RabbitMqSecPass321@rabbitmq:5672
RABBITMQ_EXCHANGE=cnweb.events

# Frontend URL (for links in email)
FRONTEND_URL=http://localhost:8080


# SendGrid Configuration Example
# Copy this to .env and fill in your actual values

# Email Provider: 'sendgrid' or 'smtp'
EMAIL_PROVIDER=sendgrid

# SendGrid API Key (get from https://app.sendgrid.com/settings/api_keys)
# Must have Mail Send permission
SENDGRID_API_KEY=SG.your_api_key_here

# Sender email (MUST be verified in SendGrid)
# Go to Settings > Sender Authentication > Verify a Single Sender
EMAIL_FROM=your_verified_email@example.com
EMAIL_FROM_NAME=Shop System

# SMTP Fallback (optional, only used if EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password

# Frontend URL (for email links)
FRONTEND_URL=https://your-domain.com

